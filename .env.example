# 공통
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Seoul

# Local google-map-scraper (used on every content generation)
GOOGLE_MAP_SCRAPER_PATH=../google-map-scraper
GOOGLE_MAP_SCRAPER_TIMEOUT=900
GOOGLE_MAP_SCRAPER_TODO_DIR=../google-map-scraper
PLACE_COLLECT_SEARCH_STRINGS=restaurant,attraction,museum,park
PLACE_COLLECT_LOCATION_QUERY=Tokyo, Japan
PLACE_COLLECT_LOCATION_QUERIES=Tokyo, Japan|Osaka, Japan|Fukuoka, Japan
PLACE_COLLECT_LANGUAGE=ko
PLACE_COLLECT_MAX_RESULTS_PER_SEARCH=120

# Google Places
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_LANGUAGE=ko
GOOGLE_PLACES_REGION=JP

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1200

# WordPress
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_REST_API_VERSION=wp/v2
WORDPRESS_META_TITLE_KEY=rank_math_title
WORDPRESS_META_DESCRIPTION_KEY=rank_math_description
WORDPRESS_META_KEYWORDS_KEY=rank_math_focus_keyword
WORDPRESS_META_CANONICAL_KEY=rank_math_canonical_url
WORDPRESS_CATEGORY_ID=
WORDPRESS_AUTHOR_ID=

# PostgreSQL (optional)
DB_URL=
PLACE_CACHE_TTL_DAYS=30
PLACE_CACHE_MIN_COUNT=20
PLACE_CACHE_FETCH_LIMIT=120
PLACE_CACHE_STRICT_FIELDS=true

# Ranking/Generation/Review 정책값
TOP_N_CANDIDATES=30
RANK_THRESHOLD=0.65
RECENT_PUBLISHED_EXCLUDE_COUNT=10
ENABLE_REVIEW_CHECK=true
GENERATION_RETRY_COUNT=2

# Scheduler
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_STORE_URL=
SCHEDULER_MAX_INSTANCES=1
SCHEDULER_CONTENT_INTERVAL_HOURS=8

# 네트워크/안정성
REQUEST_TIMEOUT_SECONDS=300
HTTP_RETRY_COUNT=3
HTTP_RETRY_BACKOFF=1.5
