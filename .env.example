# 공통
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Seoul

# Apify
APIFY_TOKEN=
APIFY_ACTOR_ID=compass/crawler-google-places
APIFY_ACTOR_TIMEOUT=900
APIFY_DISCOVERY_ACTOR_ID=
APIFY_DISCOVERY_TIMEOUT=900
APIFY_DATASET_ID=
APIFY_DATASET_IDS=
APIFY_DATASET_ITEM_LIMIT=2000
APIFY_WEBHOOK_SECRET=
DISCOVERY_SYNC_MAX_RESULTS=120
APIFY_MAX_CONCURRENT_REQUESTS=3
APIFY_SEARCH_STRINGS=restaurant,attraction,museum,park
APIFY_LOCATION_QUERY=Tokyo, Japan
APIFY_LANGUAGE=ko
APIFY_MAX_CRAWLED_PER_SEARCH=120

# Google Places
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_LANGUAGE=ko
GOOGLE_PLACES_REGION=JP

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1200

# WordPress
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_REST_API_VERSION=wp/v2
WORDPRESS_CATEGORY_ID=
WORDPRESS_AUTHOR_ID=

# PostgreSQL (optional)
DB_URL=
PLACE_CACHE_TTL_DAYS=30
PLACE_CACHE_MIN_COUNT=20
PLACE_CACHE_FETCH_LIMIT=120
PLACE_CACHE_STRICT_FIELDS=true
APIFY_FORCE_REFRESH=false
APIFY_MIN_NEW_RUN_INTERVAL_MINUTES=240

# Ranking/Generation/Review 정책값
TOP_N_CANDIDATES=30
RANK_THRESHOLD=0.65
ENABLE_REVIEW_CHECK=true
GENERATION_RETRY_COUNT=2

# Scheduler
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_STORE_URL=
SCHEDULER_MAX_INSTANCES=1
SCHEDULER_ENABLE_APIFY_COLLECT=false
SCHEDULER_CONTENT_INTERVAL_HOURS=8

# 네트워크/안정성
REQUEST_TIMEOUT_SECONDS=300
HTTP_RETRY_COUNT=3
HTTP_RETRY_BACKOFF=1.5
